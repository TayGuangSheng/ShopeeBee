# Telegram
TELEGRAM_BOT_TOKEN=123456:replace-me
BOT_MODE=polling
PUBLIC_WEBHOOK_URL=

# Optional: retained for stored user metadata. The Telegram bot exposes no admin commands.
ADMIN_USERNAMES=

# HTTP
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=file:../data/shopeebee.db

# Shopee Singapore direct affiliate links
SHOPEE_AFFILIATE_ID=
SHOPEE_AFFILIATE_SUB_ID=shopeebee
SHOPEE_EXPAND_SHORT_LINKS=true
SHOPEE_CONVERSION_TIMEOUT_MS=90000

# Bot controls
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
QUEUE_CONCURRENCY=1
MAX_LINKS_PER_MESSAGE=5
